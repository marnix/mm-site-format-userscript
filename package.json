{
  "name": "mm-site-format-userscript",
  "version": "0.13.0",
  "private": true,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "preci": "npm run clean",
    "ci": "concurrently --success all \"npm run build\" \"prettier --check .\" \"vitest run\" \"tsc --noEmit\""
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "concurrently": "^10.0.3",
    "happy-dom": "^20.10.3",
    "prettier": "^3.8.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
