{
  "name": "mm-site-format-userscript",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "ci": "npm run clean && npm run build && concurrently --success all \"prettier --check .\" \"vitest run\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "happy-dom": "^20.10.2",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
