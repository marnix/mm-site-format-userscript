{
  "name": "mm-site-format-userscript",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsup",
    "dev": "concurrently \"tsup --watch\" \"http-server dist -p 8787 --cors -c-1 --silent\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "ci": "npm run clean && npm run build && concurrently --success all \"prettier --check .\" \"vitest run\""
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "concurrently": "^9.1.2",
    "http-server": "^14.1.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
